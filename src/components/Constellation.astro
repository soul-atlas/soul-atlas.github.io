---
// A decorative, animated "constellation" — drifting nodes joined by lines when
// they drift close, echoing the Atlas's graph of connected minds. It reads the
// theme's --accent at runtime (so it works in light and dark and re-tints on
// toggle), fades away from the edges so centered text stays clean, respects
// prefers-reduced-motion, and pauses when offscreen or the tab is hidden.
---

<canvas class="constellation" aria-hidden="true"></canvas>

<style>
  .constellation {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
    pointer-events: none;
    /* Concentrate the effect toward the edges; clear behind centered content. */
    -webkit-mask-image: radial-gradient(
      ellipse 60% 58% at 50% 42%,
      transparent 0%,
      transparent 34%,
      #000 82%
    );
    mask-image: radial-gradient(
      ellipse 60% 58% at 50% 42%,
      transparent 0%,
      transparent 34%,
      #000 82%
    );
  }
</style>

<script>
  type Node = { x: number; y: number; vx: number; vy: number; r: number };

  const REDUCE = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const LINK = 132; // px distance under which two nodes are joined

  function hexToRgb(c: string): string | null {
    if (!c) return null;
    const v = c.trim();
    if (v.startsWith('#')) {
      const h = v.slice(1);
      const full =
        h.length === 3
          ? h
              .split('')
              .map((x) => x + x)
              .join('')
          : h;
      const n = parseInt(full, 16);
      if (Number.isNaN(n)) return null;
      return `${(n >> 16) & 255}, ${(n >> 8) & 255}, ${n & 255}`;
    }
    const m = v.match(/\d+(\.\d+)?/g);
    return m && m.length >= 3 ? `${m[0]}, ${m[1]}, ${m[2]}` : null;
  }

  function init(canvas: HTMLCanvasElement) {
    const ctx = canvas.getContext('2d');
    if (!ctx) return;

    const dpr = Math.min(window.devicePixelRatio || 1, 2);
    let w = 0;
    let h = 0;
    let nodes: Node[] = [];
    let raf = 0;
    let rgb = '111, 155, 255';

    function readAccent() {
      const accent = getComputedStyle(document.documentElement).getPropertyValue('--accent');
      rgb = hexToRgb(accent) ?? rgb;
    }

    function resize() {
      const rect = canvas.getBoundingClientRect();
      w = rect.width;
      h = rect.height;
      if (w === 0 || h === 0) return;
      canvas.width = Math.round(w * dpr);
      canvas.height = Math.round(h * dpr);
      ctx!.setTransform(dpr, 0, 0, dpr, 0, 0);
      const count = Math.max(16, Math.min(60, Math.round((w * h) / 22000)));
      nodes = Array.from({ length: count }, () => ({
        x: Math.random() * w,
        y: Math.random() * h,
        vx: (Math.random() - 0.5) * 0.16,
        vy: (Math.random() - 0.5) * 0.16,
        r: Math.random() * 1.3 + 0.8,
      }));
    }

    function step() {
      for (const n of nodes) {
        n.x += n.vx;
        n.y += n.vy;
        if (n.x <= 0 || n.x >= w) n.vx *= -1;
        if (n.y <= 0 || n.y >= h) n.vy *= -1;
      }
    }

    function draw() {
      ctx!.clearRect(0, 0, w, h);
      for (let i = 0; i < nodes.length; i++) {
        const a = nodes[i];
        for (let j = i + 1; j < nodes.length; j++) {
          const b = nodes[j];
          const dx = a.x - b.x;
          const dy = a.y - b.y;
          const d = Math.hypot(dx, dy);
          if (d < LINK) {
            ctx!.strokeStyle = `rgba(${rgb}, ${(1 - d / LINK) * 0.5})`;
            ctx!.lineWidth = 1;
            ctx!.beginPath();
            ctx!.moveTo(a.x, a.y);
            ctx!.lineTo(b.x, b.y);
            ctx!.stroke();
          }
        }
      }
      ctx!.fillStyle = `rgba(${rgb}, 0.7)`;
      for (const n of nodes) {
        ctx!.beginPath();
        ctx!.arc(n.x, n.y, n.r, 0, Math.PI * 2);
        ctx!.fill();
      }
    }

    function loop() {
      step();
      draw();
      raf = requestAnimationFrame(loop);
    }

    function start() {
      if (raf || REDUCE || w === 0) return;
      raf = requestAnimationFrame(loop);
    }
    function stop() {
      if (raf) cancelAnimationFrame(raf);
      raf = 0;
    }

    readAccent();
    resize();
    if (REDUCE) draw();
    else start();

    // Re-tint when the theme toggles.
    new MutationObserver(() => {
      readAccent();
      if (REDUCE) draw();
    }).observe(document.documentElement, { attributes: true, attributeFilter: ['data-theme'] });

    // Re-fit on size changes.
    let resizeTimer = 0;
    const onResize = () => {
      window.clearTimeout(resizeTimer);
      resizeTimer = window.setTimeout(() => {
        resize();
        if (REDUCE) draw();
      }, 150);
    };
    window.addEventListener('resize', onResize);

    // Pause when scrolled out of view or the tab is hidden.
    if (!REDUCE) {
      new IntersectionObserver((entries) => {
        for (const e of entries) e.isIntersecting ? start() : stop();
      }).observe(canvas);
      document.addEventListener('visibilitychange', () => {
        document.hidden ? stop() : start();
      });
    }
  }

  document.querySelectorAll<HTMLCanvasElement>('canvas.constellation').forEach((c) => init(c));
</script>
