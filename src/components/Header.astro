---
import { url, GITHUB_URL, SITE } from '../lib/site';
import ThemeToggle from './ThemeToggle.astro';

const nav = [
  { label: 'Explore', href: url('/souls') },
  { label: 'Graph', href: url('/graph') },
  { label: 'Map', href: url('/map') },
  { label: 'Dashboard', href: url('/dashboard') },
  { label: 'Compare', href: url('/compare') },
  { label: 'About', href: url('/about') },
];
const path = Astro.url.pathname;
const isActive = (href: string) =>
  path === href || path === href + '/' || (href !== url('/') && path.startsWith(href));
---

<header
  class="sticky top-0 z-50 border-b backdrop-blur"
  style="background:color-mix(in srgb, var(--bg) 86%, transparent); border-color:var(--border)"
>
  <div class="mx-auto flex h-14 max-w-6xl items-center gap-4 px-4">
    <a
      href={url('/')}
      class="flex items-center gap-2 font-semibold tracking-tight"
      style="color:var(--ink)"
    >
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <g
          stroke="var(--accent)"
          stroke-width="1.1"
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-opacity="0.45"
        >
          <path d="M6.5 7L14 4.5L19.5 9.5L16.5 17L8 18M19.5 9.5L12.5 11.5L8 18"></path>
        </g>
        <g fill="var(--accent)">
          <circle cx="6.5" cy="7" r="2.7"></circle>
          <circle cx="14" cy="4.5" r="1.5"></circle>
          <circle cx="19.5" cy="9.5" r="2.1"></circle>
          <circle cx="16.5" cy="17" r="1.8"></circle>
          <circle cx="8" cy="18" r="1.5"></circle>
          <circle cx="12.5" cy="11.5" r="1.2"></circle>
        </g>
        <g fill="var(--accent)" fill-opacity="0.4">
          <circle cx="20.5" cy="18.5" r="0.85"></circle>
          <circle cx="4" cy="13.5" r="0.85"></circle>
        </g>
      </svg>
      <span>SOUL <span style="color:var(--ink-faint)">Atlas</span></span>
    </a>

    <nav class="ml-2 hidden items-center gap-1 md:flex" aria-label="Primary">
      {
        nav.map((item) => (
          <a
            href={item.href}
            class="rounded-md px-3 py-1.5 text-sm transition-colors"
            style={`color:${isActive(item.href) ? 'var(--ink)' : 'var(--ink-soft)'};${isActive(item.href) ? 'background:var(--bg-soft)' : ''}`}
            aria-current={isActive(item.href) ? 'page' : undefined}
          >
            {item.label}
          </a>
        ))
      }
    </nav>

    <div class="ml-auto flex items-center gap-2">
      <button
        id="open-search"
        class="btn !px-2.5 !py-1.5 text-sm"
        aria-label="Search (press / or Ctrl+K)"
        title="Search — Ctrl/Cmd + K"
      >
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <circle cx="11" cy="11" r="7" stroke="currentColor" stroke-width="2"></circle>
          <path d="m20 20-3-3" stroke="currentColor" stroke-width="2" stroke-linecap="round"></path>
        </svg>
        <span class="hidden sm:inline" style="color:var(--ink-faint)">Search</span>
        <kbd
          class="hidden rounded border px-1 text-[10px] sm:inline"
          style="border-color:var(--border)">⌘K</kbd
        >
      </button>
      <ThemeToggle />
      <a
        href={GITHUB_URL}
        class="btn !px-2.5 !py-1.5"
        aria-label={`${SITE.name} on GitHub`}
        title="GitHub"
        rel="noopener"
      >
        <svg width="17" height="17" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path
            d="M12 .5C5.7.5.5 5.7.5 12c0 5.1 3.3 9.4 7.9 10.9.6.1.8-.2.8-.5v-2c-3.2.7-3.9-1.4-3.9-1.4-.5-1.3-1.3-1.7-1.3-1.7-1-.7.1-.7.1-.7 1.2.1 1.8 1.2 1.8 1.2 1 1.8 2.7 1.3 3.4 1 .1-.8.4-1.3.7-1.6-2.6-.3-5.3-1.3-5.3-5.8 0-1.3.5-2.3 1.2-3.1-.1-.3-.5-1.5.1-3.1 0 0 1-.3 3.3 1.2a11.5 11.5 0 0 1 6 0C17.3 4.6 18.3 5 18.3 5c.6 1.6.2 2.8.1 3.1.8.8 1.2 1.8 1.2 3.1 0 4.5-2.7 5.5-5.3 5.8.4.4.8 1.1.8 2.2v3.3c0 .3.2.6.8.5 4.6-1.5 7.9-5.8 7.9-10.9C23.5 5.7 18.3.5 12 .5Z"
          ></path>
        </svg>
      </a>
      <button id="open-search-mobile" class="btn !px-2.5 !py-1.5 md:hidden" aria-label="Menu"
        >☰</button
      >
    </div>
  </div>
</header>
