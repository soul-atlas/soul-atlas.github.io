---
// "Chat with this SOUL" — a bring-your-own-key chat, grounded in the SOUL.md.
// Supports Claude (Anthropic), OpenAI, and Gemini: the visitor picks a provider
// + model and supplies their own key.
//
// Security model (the site is fully static — no backend ever sees the key or
// the messages):
//   • Each provider's request endpoint is HARDCODED and chosen from a fixed
//     list — there is no free-text endpoint, so a key can only ever be sent to
//     that provider's official host (api.anthropic.com / api.openai.com /
//     generativelanguage.googleapis.com).
//   • Keys are per-provider, kept in memory for the session; persisted to
//     localStorage ONLY on opt-in ("remember on this device") and wiped by
//     "Forget key". Typed into a password field; never written to the DOM, a
//     data-attribute, the URL, or the console.
//   • All chat content (model output + the fetched SOUL.md) is rendered with
//     textContent — never innerHTML — so a response can't inject markup/script.
interface Props {
  slug: string;
  title: string;
  category: string;
  color?: string;
  sensitive?: boolean;
  verified?: boolean;
}
const {
  slug,
  title,
  category,
  color = '#6f9bff',
  sensitive = false,
  verified = false,
} = Astro.props;
const base = import.meta.env.BASE_URL;
const mdUrl = `${base}api/souls/${slug}.md`;
---

<button
  type="button"
  class="btn btn-accent mt-5 inline-flex items-center gap-1.5"
  data-chat-open
  style="color:#fff"
>
  💬 Chat with this SOUL
</button>

<div
  id="chat-panel"
  class="fixed inset-y-0 right-0 z-50 hidden w-full max-w-md flex-col border-l shadow-2xl"
  style="background:var(--bg); border-color:var(--border)"
  role="dialog"
  aria-modal="true"
  aria-label={`Chat with ${title}`}
  data-md={mdUrl}
  data-title={title}
  data-category={category}
  data-color={color}
  data-sensitive={sensitive ? '1' : '0'}
  data-verified={verified ? '1' : '0'}
>
  <!-- Header -->
  <div class="flex items-center gap-2 border-b px-4 py-3" style="border-color:var(--border)">
    <div class="min-w-0 flex-1">
      <div class="truncate text-sm font-semibold" style="color:var(--ink)">Chat with {title}</div>
      <div class="text-xs" style="color:var(--ink-faint)">{category}</div>
    </div>
    <button
      type="button"
      data-chat-settings
      class="rounded-md border px-2 py-1 text-xs"
      style="border-color:var(--border); color:var(--ink-soft)"
      title="Settings">⚙</button
    >
    <button
      type="button"
      data-chat-close
      class="rounded-md border px-2 py-1 text-xs"
      style="border-color:var(--border); color:var(--ink-soft)"
      aria-label="Close chat">✕</button
    >
  </div>

  <!-- Disclaimer -->
  <div
    class="border-b px-4 py-2 text-xs leading-snug"
    style="border-color:var(--border); color:var(--ink-faint); background:var(--bg-soft)"
  >
    {
      sensitive
        ? 'This is an AI grounded in a community-written portrait of how this role thinks — not a real practitioner and not professional advice. For medical, legal, or financial decisions, consult a qualified professional.'
        : 'This is an AI grounded in a community-written portrait of how this role thinks — a thinking aid, not a real practitioner or professional advice.'
    }
    {!verified && ' This SOUL is AI-drafted and unverified.'}
  </div>

  <!-- Settings drawer -->
  <div
    data-chat-settings-panel
    class="hidden border-b px-4 py-3 text-sm"
    style="border-color:var(--border); background:var(--bg-soft)"
  >
    <label class="block text-xs font-medium" style="color:var(--ink-soft)">
      Provider
      <select
        data-chat-provider
        class="mt-1 w-full rounded-md border bg-transparent px-2 py-1.5 text-sm outline-none"
        style="border-color:var(--border); color:var(--ink)"
      >
        <option value="anthropic">Claude (Anthropic)</option>
        <option value="openai">OpenAI</option>
        <option value="gemini">Gemini (Google)</option>
      </select>
    </label>
    <label class="mt-2 block text-xs font-medium" style="color:var(--ink-soft)">
      API key
      <input
        type="password"
        autocomplete="off"
        autocapitalize="off"
        autocorrect="off"
        spellcheck="false"
        data-chat-key
        class="mt-1 w-full rounded-md border bg-transparent px-2 py-1.5 text-sm outline-none"
        style="border-color:var(--border); color:var(--ink)"
      />
    </label>
    <label class="mt-2 flex items-center gap-2 text-xs" style="color:var(--ink-soft)">
      <input type="checkbox" data-chat-remember /> Remember on this device
    </label>
    <label class="mt-2 block text-xs font-medium" style="color:var(--ink-soft)">
      Model
      <select
        data-chat-model
        class="mt-1 w-full rounded-md border bg-transparent px-2 py-1.5 text-sm outline-none"
        style="border-color:var(--border); color:var(--ink)"
      >
      </select>
    </label>
    <div class="mt-3 flex items-center gap-2">
      <button
        type="button"
        data-chat-save
        class="btn btn-accent text-xs"
        style="color:#fff; padding:0.3rem 0.7rem">Save</button
      >
      <button
        type="button"
        data-chat-forget
        class="rounded-md border px-2 py-1 text-xs"
        style="border-color:var(--border); color:var(--ink-soft)">Forget key</button
      >
    </div>
    <p data-chat-privacy class="mt-2 text-xs leading-snug" style="color:var(--ink-faint)"></p>
  </div>

  <!-- Messages -->
  <div data-chat-log class="flex-1 space-y-3 overflow-y-auto px-4 py-4 text-sm"></div>

  <!-- Composer -->
  <form data-chat-form class="border-t p-3" style="border-color:var(--border)">
    <div class="flex items-end gap-2">
      <textarea
        data-chat-input
        rows="1"
        placeholder={`Ask ${title} how they'd think about…`}
        class="max-h-32 flex-1 resize-none rounded-md border bg-transparent px-3 py-2 text-sm outline-none"
        style="border-color:var(--border); color:var(--ink)"></textarea>
      <button type="submit" data-chat-send class="btn btn-accent" style="color:#fff">Send</button>
    </div>
  </form>
</div>
<div
  id="chat-backdrop"
  class="fixed inset-0 z-40 hidden"
  style="background:rgba(0,0,0,0.35)"
  data-chat-backdrop
>
</div>

<!-- Global (not scoped): these style JS-created message nodes, which don't carry
     Astro's scope attribute. All class names are chat-* to avoid collisions. -->
<style is:global>
  .chat-row {
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
  }
  .chat-row.user {
    flex-direction: row-reverse;
  }
  .chat-av {
    flex: 0 0 auto;
    width: 28px;
    height: 28px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.78rem;
    font-weight: 700;
    color: #fff;
  }
  .chat-av.user {
    background: var(--ink-faint);
  }
  .chat-bubble {
    max-width: 80%;
    padding: 0.5rem 0.75rem;
    border-radius: 0.9rem;
    line-height: 1.5;
    white-space: pre-wrap;
    overflow-wrap: anywhere;
  }
  .chat-row.soul .chat-bubble {
    background: var(--surface);
    border: 1px solid var(--border);
    color: var(--ink);
    border-top-left-radius: 0.25rem;
  }
  .chat-row.user .chat-bubble {
    background: var(--accent-soft);
    color: var(--ink);
    border-top-right-radius: 0.25rem;
  }
  .chat-typing {
    display: inline-flex;
    gap: 4px;
    padding: 0.15rem 0;
  }
  .chat-typing span {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--ink-faint);
    animation: chat-dot 1s infinite ease-in-out;
  }
  .chat-typing span:nth-child(2) {
    animation-delay: 0.15s;
  }
  .chat-typing span:nth-child(3) {
    animation-delay: 0.3s;
  }
  @keyframes chat-dot {
    0%,
    60%,
    100% {
      opacity: 0.25;
      transform: translateY(0);
    }
    30% {
      opacity: 1;
      transform: translateY(-3px);
    }
  }
  .chat-error {
    display: flex;
    gap: 0.5rem;
    align-items: flex-start;
    border: 1px solid rgba(224, 83, 61, 0.4);
    background: rgba(224, 83, 61, 0.08);
    color: var(--ink);
    border-radius: 0.6rem;
    padding: 0.5rem 0.7rem;
    font-size: 0.85rem;
  }
  .chat-error .ico {
    color: #e0533d;
    flex: 0 0 auto;
  }
  .chat-retry {
    margin-top: 0.3rem;
    color: var(--accent);
    font-weight: 600;
  }
  .chat-empty {
    color: var(--ink-faint);
  }
  .chat-suggest {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-top: 0.6rem;
  }
  .chat-suggest button {
    border: 1px solid var(--border);
    border-radius: 999px;
    padding: 0.3rem 0.7rem;
    font-size: 0.8rem;
    color: var(--ink-soft);
    text-align: left;
  }
  .chat-suggest button:hover {
    color: var(--accent);
    border-color: var(--accent);
  }
  @media (prefers-reduced-motion: reduce) {
    .chat-typing span {
      animation: none;
    }
  }
</style>

<script>
  type Msg = { role: 'user' | 'assistant'; content: string };

  // Each provider's endpoint is hardcoded here and selected from a fixed list.
  // A key is only ever sent to the matching official host — never anywhere else.
  const PROVIDERS: Record<
    string,
    {
      host: string;
      keyHint: string;
      keyUrl: string;
      models: string[];
      endpoint: (model: string) => string;
      headers: (key: string) => Record<string, string>;
      body: (system: string, messages: Msg[], model: string) => unknown;
      extract: (evt: any) => string;
    }
  > = {
    anthropic: {
      host: 'api.anthropic.com',
      keyHint: 'sk-ant-…',
      keyUrl: 'console.anthropic.com',
      models: ['claude-opus-4-8', 'claude-sonnet-4-6', 'claude-haiku-4-5'],
      endpoint: () => 'https://api.anthropic.com/v1/messages',
      headers: (key) => ({
        'content-type': 'application/json',
        'x-api-key': key,
        'anthropic-version': '2023-06-01',
        'anthropic-dangerous-direct-browser-access': 'true',
      }),
      body: (system, messages, model) => ({
        model,
        max_tokens: 1024,
        system: [{ type: 'text', text: system, cache_control: { type: 'ephemeral' } }],
        messages,
        stream: true,
      }),
      extract: (e) =>
        e.type === 'content_block_delta' && e.delta?.type === 'text_delta' ? e.delta.text : '',
    },
    openai: {
      host: 'api.openai.com',
      keyHint: 'sk-…',
      keyUrl: 'platform.openai.com',
      models: ['gpt-4o', 'gpt-4o-mini', 'gpt-4.1'],
      endpoint: () => 'https://api.openai.com/v1/chat/completions',
      headers: (key) => ({ 'content-type': 'application/json', authorization: `Bearer ${key}` }),
      body: (system, messages, model) => ({
        model,
        max_tokens: 1024,
        stream: true,
        messages: [{ role: 'system', content: system }, ...messages],
      }),
      extract: (e) => e.choices?.[0]?.delta?.content || '',
    },
    gemini: {
      host: 'generativelanguage.googleapis.com',
      keyHint: 'AIza…',
      keyUrl: 'aistudio.google.com',
      models: ['gemini-2.0-flash', 'gemini-1.5-pro', 'gemini-1.5-flash'],
      endpoint: (model) =>
        `https://generativelanguage.googleapis.com/v1beta/models/${model}:streamGenerateContent?alt=sse`,
      headers: (key) => ({ 'content-type': 'application/json', 'x-goog-api-key': key }),
      body: (system, messages) => ({
        systemInstruction: { parts: [{ text: system }] },
        contents: messages.map((m) => ({
          role: m.role === 'assistant' ? 'model' : 'user',
          parts: [{ text: m.content }],
        })),
        generationConfig: { maxOutputTokens: 1024 },
      }),
      extract: (e) => e.candidates?.[0]?.content?.parts?.[0]?.text || '',
    },
  };

  const REMEMBER_STORE = 'soul-chat-remember';
  const PROVIDER_STORE = 'soul-chat-provider';
  const keyStore = (p: string) => `soul-chat-key-${p}`;
  const modelStore = (p: string) => `soul-chat-model-${p}`;

  const panel = document.getElementById('chat-panel');
  if (panel) init(panel);

  function init(panel: HTMLElement) {
    const $ = <T extends HTMLElement>(sel: string) => panel.querySelector(sel) as T;
    const backdrop = document.getElementById('chat-backdrop')!;
    const openBtn = document.querySelector('[data-chat-open]') as HTMLButtonElement;
    const log = $('[data-chat-log]') as HTMLElement;
    const form = $('[data-chat-form]') as HTMLFormElement;
    const input = $('[data-chat-input]') as HTMLTextAreaElement;
    const providerSel = $('[data-chat-provider]') as HTMLSelectElement;
    const keyInput = $('[data-chat-key]') as HTMLInputElement;
    const rememberInput = $('[data-chat-remember]') as HTMLInputElement;
    const modelSel = $('[data-chat-model]') as HTMLSelectElement;
    const settingsPanel = $('[data-chat-settings-panel]') as HTMLElement;
    const privacy = $('[data-chat-privacy]') as HTMLElement;

    const title = panel.dataset.title || 'this SOUL';
    const mdUrl = panel.dataset.md!;
    const sensitive = panel.dataset.sensitive === '1';
    const soulColor = panel.dataset.color || '#6f9bff';
    const soulInitial = (title.trim()[0] || '?').toUpperCase();
    const SUGGESTIONS = [
      'What would you watch for that a novice would miss?',
      "Walk me through how you'd approach a hard call.",
      'What do people most often get wrong about your work?',
    ];

    const safe = <T,>(fn: () => T, fallback: T): T => {
      try {
        return fn();
      } catch {
        return fallback;
      }
    };

    // Keys are per provider; only read from storage when "remember" is on.
    let remember = safe(() => localStorage.getItem(REMEMBER_STORE) === '1', false);
    let provider = safe(() => localStorage.getItem(PROVIDER_STORE), null) || 'anthropic';
    if (!PROVIDERS[provider]) provider = 'anthropic';
    const keys: Record<string, string> = { anthropic: '', openai: '', gemini: '' };
    if (remember) {
      for (const p of Object.keys(PROVIDERS))
        keys[p] = safe(() => localStorage.getItem(keyStore(p)) || '', '');
    }

    function fillModels(p: string) {
      const saved = safe(() => localStorage.getItem(modelStore(p)), null);
      modelSel.replaceChildren(); // clear without innerHTML
      for (const m of PROVIDERS[p].models) {
        const opt = document.createElement('option');
        opt.value = m;
        opt.textContent = m; // model id as text — safe, no markup
        modelSel.appendChild(opt);
      }
      if (saved && PROVIDERS[p].models.includes(saved)) modelSel.value = saved;
    }

    function syncProviderUI() {
      const cfg = PROVIDERS[provider];
      keyInput.value = keys[provider] || '';
      keyInput.placeholder = cfg.keyHint;
      fillModels(provider);
      privacy.textContent = `Your key stays in this browser and is sent only to ${cfg.host}. This site has no server and never sees your key or messages. Get a key at ${cfg.keyUrl}.`;
    }

    providerSel.value = provider;
    rememberInput.checked = remember;
    syncProviderUI();

    let system: string | null = null;
    let busy = false;
    let controller: AbortController | null = null;
    const history: Msg[] = [];

    function open() {
      panel.style.display = 'flex';
      backdrop.style.display = 'block';
      if (!keys[provider]) settingsPanel.classList.remove('hidden');
      showSuggestions();
      (keys[provider] ? input : keyInput).focus();
    }
    function close() {
      panel.style.display = 'none';
      backdrop.style.display = 'none';
      controller?.abort();
    }
    openBtn?.addEventListener('click', open);
    $('[data-chat-close]').addEventListener('click', close);
    backdrop.addEventListener('click', close);
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && panel.style.display === 'flex') close();
    });
    $('[data-chat-settings]').addEventListener('click', () =>
      settingsPanel.classList.toggle('hidden'),
    );

    providerSel.addEventListener('change', () => {
      provider = providerSel.value;
      syncProviderUI();
    });

    $('[data-chat-save]').addEventListener('click', () => {
      keys[provider] = keyInput.value.trim();
      remember = rememberInput.checked;
      safe(() => {
        localStorage.setItem(PROVIDER_STORE, provider);
        localStorage.setItem(modelStore(provider), modelSel.value);
        if (remember) {
          localStorage.setItem(REMEMBER_STORE, '1');
          for (const p of Object.keys(PROVIDERS)) {
            if (keys[p]) localStorage.setItem(keyStore(p), keys[p]);
          }
        } else {
          localStorage.removeItem(REMEMBER_STORE);
          for (const p of Object.keys(PROVIDERS)) localStorage.removeItem(keyStore(p));
        }
      }, undefined);
      settingsPanel.classList.add('hidden');
      input.focus();
    });
    $('[data-chat-forget]').addEventListener('click', () => {
      keys[provider] = '';
      keyInput.value = '';
      safe(() => localStorage.removeItem(keyStore(provider)), undefined);
    });

    // Rendering — built with the DOM API + textContent only, never innerHTML.
    const scroll = () => (log.scrollTop = log.scrollHeight);

    function userIcon(): SVGSVGElement {
      const ns = 'http://www.w3.org/2000/svg';
      const svg = document.createElementNS(ns, 'svg');
      svg.setAttribute('viewBox', '0 0 24 24');
      svg.setAttribute('width', '15');
      svg.setAttribute('height', '15');
      svg.setAttribute('fill', '#fff');
      const path = document.createElementNS(ns, 'path');
      path.setAttribute(
        'd',
        'M12 12a5 5 0 100-10 5 5 0 000 10zm0 2c-5 0-9 2.6-9 6v1h18v-1c0-3.4-4-6-9-6z',
      );
      svg.appendChild(path);
      return svg;
    }

    function newRow(role: 'user' | 'soul'): HTMLElement {
      const row = document.createElement('div');
      row.className = `chat-row ${role}`;
      const av = document.createElement('div');
      av.className = `chat-av ${role}`;
      if (role === 'soul') {
        av.style.background = soulColor;
        av.textContent = soulInitial;
      } else {
        av.appendChild(userIcon());
      }
      const bubble = document.createElement('div');
      bubble.className = 'chat-bubble';
      row.append(av, bubble);
      log.appendChild(row);
      scroll();
      return bubble;
    }

    function addUser(text: string) {
      newRow('user').textContent = text;
    }

    // Soul bubble that begins as a typing indicator; returns setters.
    function startSoul() {
      const bubble = newRow('soul');
      const typing = document.createElement('span');
      typing.className = 'chat-typing';
      for (let i = 0; i < 3; i++) typing.appendChild(document.createElement('span'));
      bubble.appendChild(typing);
      const row = bubble.parentElement;
      return {
        set(text: string) {
          bubble.textContent = text;
          scroll();
        },
        remove() {
          row?.remove();
        },
      };
    }

    function addError(msg: string, retry?: () => void) {
      const el = document.createElement('div');
      el.className = 'chat-error';
      const ico = document.createElement('span');
      ico.className = 'ico';
      ico.textContent = '⚠';
      const wrap = document.createElement('div');
      const m = document.createElement('div');
      m.textContent = msg;
      wrap.appendChild(m);
      if (retry) {
        const btn = document.createElement('button');
        btn.type = 'button';
        btn.className = 'chat-retry';
        btn.textContent = 'Retry';
        btn.addEventListener('click', () => {
          el.remove();
          retry();
        });
        wrap.appendChild(btn);
      }
      el.append(ico, wrap);
      log.appendChild(el);
      scroll();
    }

    // Empty-state greeting + suggested prompts.
    let suggestEl: HTMLElement | null = null;
    function showSuggestions() {
      if (suggestEl || history.length) return;
      suggestEl = document.createElement('div');
      suggestEl.className = 'chat-empty';
      const greet = document.createElement('div');
      greet.textContent = `Ask ${title} how they think — in their own frameworks.`;
      const chips = document.createElement('div');
      chips.className = 'chat-suggest';
      for (const s of SUGGESTIONS) {
        const b = document.createElement('button');
        b.type = 'button';
        b.textContent = s;
        b.addEventListener('click', () => send(s));
        chips.appendChild(b);
      }
      suggestEl.append(greet, chips);
      log.appendChild(suggestEl);
    }
    function clearSuggestions() {
      suggestEl?.remove();
      suggestEl = null;
    }

    async function ensureSystem(): Promise<string> {
      if (system) return system;
      const md = await (await fetch(mdUrl)).text();
      system =
        'You are in conversation as someone who embodies the way of thinking described in the ' +
        'SOUL below. Adopt its mental models, priorities, decision frameworks, and heuristics; ' +
        'ask the questions an expert in this domain would ask; speak in the first person as that ' +
        'mind. Be honest about uncertainty and trade-offs. Do not claim real-world credentials, ' +
        'identity, or authority — you are a portrait of how this role thinks, generated by an AI.' +
        (sensitive
          ? ' This domain involves high-stakes decisions: do not give individualized medical, ' +
            'legal, or financial advice or anything that could be relied upon as such — explain ' +
            'how a practitioner reasons, and tell the user to consult a qualified professional.'
          : '') +
        `\n\n<soul>\n${md}\n</soul>`;
      return system;
    }

    async function send(text: string) {
      if (busy) return;
      const cfg = PROVIDERS[provider];
      const key = keys[provider];
      if (!key) {
        settingsPanel.classList.remove('hidden');
        addError('Add your API key in settings (⚙) to start chatting.');
        keyInput.focus();
        return;
      }
      clearSuggestions();
      busy = true;
      addUser(text);
      history.push({ role: 'user', content: text });
      const out = startSoul();
      const model = modelSel.value || cfg.models[0];

      controller = new AbortController();
      let acc = '';
      try {
        const sys = await ensureSystem();
        const res = await fetch(cfg.endpoint(model), {
          method: 'POST',
          signal: controller.signal,
          headers: cfg.headers(key),
          body: JSON.stringify(cfg.body(sys, history, model)),
        });

        if (!res.ok || !res.body) {
          const err = await res.json().catch(() => null);
          const msg =
            res.status === 401 || res.status === 403
              ? 'Invalid API key (or this key lacks access to that model).'
              : res.status === 429
                ? 'Rate limited — try again shortly.'
                : err?.error?.message || `Request failed (${res.status}).`;
          out.remove();
          history.pop();
          addError(msg, () => send(text));
          return;
        }

        const reader = res.body.getReader();
        const decoder = new TextDecoder();
        let buf = '';
        for (;;) {
          const { value, done } = await reader.read();
          if (done) break;
          buf += decoder.decode(value, { stream: true });
          const lines = buf.split('\n');
          buf = lines.pop() || '';
          for (const line of lines) {
            const t = line.trim();
            if (!t.startsWith('data:')) continue;
            const payload = t.slice(5).trim();
            if (!payload || payload === '[DONE]') continue;
            let evt: any;
            try {
              evt = JSON.parse(payload);
            } catch {
              continue;
            }
            if (evt?.type === 'error') throw new Error(evt.error?.message || 'stream error');
            const piece = cfg.extract(evt);
            if (piece) {
              acc += piece;
              out.set(acc);
            }
          }
        }
        if (!acc) out.set('(no response)');
        history.push({ role: 'assistant', content: acc });
      } catch (e: any) {
        if (e?.name !== 'AbortError') {
          out.remove();
          history.pop();
          addError(e?.message || 'Something went wrong.', () => send(text));
        }
      } finally {
        busy = false;
        controller = null;
      }
    }

    form.addEventListener('submit', (e) => {
      e.preventDefault();
      const text = input.value.trim();
      if (!text) return;
      input.value = '';
      input.style.height = 'auto';
      send(text);
    });
    input.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' && !e.shiftKey) {
        e.preventDefault();
        form.requestSubmit();
      }
    });
    input.addEventListener('input', () => {
      input.style.height = 'auto';
      input.style.height = Math.min(input.scrollHeight, 128) + 'px';
    });
  }
</script>
