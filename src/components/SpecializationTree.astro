---
// Renders a SOUL specialization tree (see getSpecializationTree in lib/data).
// Recursive: each node is an <li> that may contain a nested <ul> of children.
// Resolved nodes link to their SOUL page; the current SOUL is highlighted.
import type { SpecNode } from '../lib/data';
import { url } from '../lib/site';
import Self from './SpecializationTree.astro';

interface Props {
  node: SpecNode;
  root?: boolean;
}
const { node, root = false } = Astro.props;

const labelClass = ['spec-label', node.current ? 'is-current' : '', node.slug ? '' : 'is-leaf']
  .filter(Boolean)
  .join(' ');
---

{
  root ? (
    <ul class="spec-tree" role="tree">
      <Self node={node} />
    </ul>
  ) : (
    <li class="spec-item" role="treeitem">
      {node.slug && !node.current ? (
        <a class={labelClass} href={url(`/souls/${node.slug}`)}>
          {node.title}
        </a>
      ) : (
        <span class={labelClass} aria-current={node.current ? 'page' : undefined}>
          {node.title}
        </span>
      )}
      {node.children.length > 0 && (
        <ul class="spec-children" role="group">
          {node.children.map((child) => (
            <Self node={child} />
          ))}
        </ul>
      )}
    </li>
  )
}

<style>
  .spec-tree,
  .spec-children {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .spec-children {
    margin-left: 0.5rem;
    padding-left: 0.75rem;
    border-left: 1px solid var(--border);
  }
  .spec-item {
    position: relative;
    padding: 0.18rem 0;
  }
  /* connector tick from the branch line to each child label */
  .spec-children > .spec-item::before {
    content: '';
    position: absolute;
    left: -0.75rem;
    top: 0.85rem;
    width: 0.6rem;
    height: 1px;
    background: var(--border);
  }
  .spec-label {
    display: inline-block;
    font-size: 0.875rem;
    line-height: 1.3;
    color: var(--ink-soft);
    text-decoration: none;
  }
  a.spec-label:hover {
    color: var(--accent);
    text-decoration: underline;
  }
  .spec-label.is-leaf {
    color: var(--ink-faint);
  }
  .spec-label.is-current {
    color: var(--ink);
    font-weight: 600;
    background: var(--accent-soft);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 0.05rem 0.45rem;
  }
</style>
