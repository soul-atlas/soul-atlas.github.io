---
// Reusable interactive force-directed knowledge graph (D3). Used full-page on
// /graph and as a scoped neighborhood on each SOUL page.
//
// Props:
//   endpoint  — URL to fetch {nodes, edges} from (default: the full graph API)
//   data      — inline {nodes, edges} to render instead of fetching
//   focus     — slug to center/highlight (neighborhood mode)
//   height    — px height of the canvas
//   controls  — show filter/search controls
import { url } from '../lib/site';
import { CATEGORY_COLORS } from '../lib/data';

interface Props {
  endpoint?: string;
  data?: { nodes: any[]; edges: any[] } | null;
  focus?: string | null;
  height?: number;
  controls?: boolean;
  id?: string;
}
const {
  endpoint = url('/api/graph.json'),
  data = null,
  focus = null,
  height = 600,
  controls = false,
  id = 'graph',
} = Astro.props;

const cats = Object.entries(CATEGORY_COLORS);
const base = import.meta.env.BASE_URL;
---

<div class="graph-wrap" data-graph-id={id}>
  {
    controls && (
      <div class="mb-3 flex flex-wrap items-center gap-2">
        <input
          type="text"
          class="rounded-md border bg-transparent px-3 py-1.5 text-sm outline-none"
          style="border-color:var(--border); color:var(--ink)"
          placeholder="Find a node…"
          data-graph-search
        />
        <select
          class="rounded-md border bg-transparent px-2 py-1.5 text-sm outline-none"
          style="border-color:var(--border); color:var(--ink)"
          data-graph-filter
        >
          <option value="">All categories</option>
          {cats.map(([name]) => (
            <option value={name}>{name}</option>
          ))}
        </select>
        <select
          class="rounded-md border bg-transparent px-2 py-1.5 text-sm outline-none"
          style="border-color:var(--border); color:var(--ink)"
          data-graph-group
          aria-label="Cluster the layout"
        >
          <option value="category">Cluster by category</option>
          <option value="kind">Cluster by kind</option>
          <option value="none">No clustering</option>
        </select>
        <div
          class="hidden flex-wrap items-center gap-1"
          data-graph-kind-chips
          role="group"
          aria-label="Filter by kind (toggle any number)"
        />
        <button
          type="button"
          class="rounded-md border px-2.5 py-1.5 text-sm"
          style="border-color:var(--border); color:var(--ink-soft)"
          data-graph-random
          title="Jump to a random SOUL"
        >
          🎲 Surprise me
        </button>
        <button
          type="button"
          class="rounded-md border px-2.5 py-1.5 text-sm"
          style="border-color:var(--border); color:var(--ink-soft)"
          data-graph-reset
          title="Clear filters and recenter"
        >
          Reset
        </button>
        <button
          type="button"
          class="rounded-md border px-2.5 py-1.5 text-sm"
          style="border-color:var(--border); color:var(--ink-soft)"
          data-graph-fullscreen
          title="Maximize the graph"
        >
          ⤢ Fullscreen
        </button>
        <span class="text-xs" style="color:var(--ink-faint)" data-graph-count />
        <span class="ml-auto text-xs" style="color:var(--ink-faint)">
          drag · scroll to zoom · hover to isolate · click to open
        </span>
      </div>
    )
  }
  <div
    class="card relative overflow-hidden"
    style={`height:${height}px`}
    data-graph-canvas
    data-endpoint={data ? '' : endpoint}
    data-focus={focus ?? ''}
    data-base={base}
  >
    <svg width="100%" height="100%" role="img" aria-label="Knowledge graph of SOULs"></svg>
    <div
      class="pointer-events-none absolute left-3 top-3 hidden rounded-md px-2.5 py-1.5 text-xs shadow"
      style="background:var(--surface); border:1px solid var(--border); color:var(--ink)"
      data-graph-tip
    >
    </div>
  </div>
  {data && <script type="application/json" data-graph-data set:html={JSON.stringify(data)} />}
</div>

<script>
  import * as d3 from 'd3';

  const CATEGORY_COLORS: Record<string, string> = {
    Technology: '#3b82f6',
    Healthcare: '#ef4444',
    'Skilled Trades': '#f59e0b',
    Engineering: '#8b5cf6',
    Science: '#06b6d4',
    Education: '#10b981',
    Business: '#6366f1',
    Government: '#64748b',
    Military: '#4b5563',
    Law: '#0ea5e9',
    Transportation: '#14b8a6',
    Agriculture: '#84cc16',
    Hospitality: '#ec4899',
    Creative: '#f472b6',
    Sports: '#22c55e',
    Entertainment: '#a855f7',
    Finance: '#eab308',
    'Public Service': '#0891b2',
    Historical: '#a16207',
    Emerging: '#d946ef',
    'Life Roles': '#fb7185',
  };
  const color = (c: string) => CATEGORY_COLORS[c] ?? '#94a3b8';

  // Kind is encoded by node SHAPE (colour stays = category). Occupations are
  // circles (the overwhelming majority); other ways of thinking get a distinct
  // glyph so they read at a glance.
  const KIND_SYMBOLS: Record<string, any> = {
    occupation: d3.symbolCircle,
    discipline: d3.symbolDiamond,
    role: d3.symbolSquare,
    identity: d3.symbolTriangle,
    community: d3.symbolWye,
    historical: d3.symbolCross,
    'agent-persona': d3.symbolStar,
  };
  const KIND_LABELS: Record<string, string> = {
    occupation: 'Occupation',
    discipline: 'Discipline',
    role: 'Role',
    identity: 'Identity',
    community: 'Community',
    historical: 'Historical',
    'agent-persona': 'Agent persona',
  };
  const symbolFor = (kind: string) => KIND_SYMBOLS[kind] ?? d3.symbolCircle;

  async function initGraph(wrap: Element) {
    const canvas = wrap.querySelector('[data-graph-canvas]') as HTMLElement;
    if (!canvas) return;
    const endpoint = canvas.dataset.endpoint;
    const focus = canvas.dataset.focus || null;
    const base = (canvas.dataset.base || '/').replace(/\/$/, '');

    let data: { nodes: any[]; edges: any[] };
    const inline = wrap.querySelector('[data-graph-data]');
    if (inline) {
      data = JSON.parse(inline.textContent || '{"nodes":[],"edges":[]}');
    } else if (endpoint) {
      try {
        data = await (await fetch(endpoint)).json();
      } catch {
        return;
      }
    } else {
      return;
    }

    const svgEl = canvas.querySelector('svg') as SVGSVGElement;
    const tip = wrap.querySelector('[data-graph-tip]') as HTMLElement;
    const W = canvas.clientWidth || 800;
    const H = canvas.clientHeight || 600;

    const nodes = data.nodes.map((n) => ({ ...n }));
    const idset = new Set(nodes.map((n) => n.id));
    const links = data.edges
      .filter((e) => idset.has(e.source) && idset.has(e.target))
      .map((e) => ({ ...e }));

    const svg = d3.select(svgEl).attr('viewBox', `0 0 ${W} ${H}`);
    svg.selectAll('*').remove();
    const root = svg.append('g');

    let zoomK = 1;
    const zoom = d3
      .zoom<SVGSVGElement, unknown>()
      .scaleExtent([0.15, 6])
      .on('zoom', (ev) => {
        root.attr('transform', ev.transform);
        // Reveal all labels once zoomed in past a threshold (and re-hide on out).
        const crossed = ev.transform.k >= 1.8 !== zoomK >= 1.8;
        zoomK = ev.transform.k;
        // Labels live inside the zoomed <g>, so they'd grow with everything else
        // and turn into an unreadable pile-up. Counter-scale them by 1/k so they
        // stay a constant ~11px on screen, anchored just off each node's edge.
        scaleLabels(zoomK);
        if (crossed) refreshLabels();
      });
    svg.call(zoom as any);

    const linkStroke: Record<string, string> = {
      // --border is nearly invisible in dark mode; most cross-kind edges are
      // "related", so stroke them in a muted-but-visible ink instead.
      related: 'var(--ink-faint)',
      specialization: '#8b5cf6',
      prerequisite: '#f59e0b',
      adjacent: '#06b6d4',
      collaboration: '#10b981',
      progression: '#ec4899',
    };

    const sizeScale = d3
      .scaleSqrt()
      .domain([0, d3.max(nodes, (d: any) => d.degree) || 1])
      .range([3.5, 16]);

    const link = root
      .append('g')
      .attr('fill', 'none')
      .attr('stroke-opacity', 1)
      .selectAll('line')
      .data(links)
      .join('line')
      .attr('stroke', (d: any) => linkStroke[d.type] || 'var(--border)')
      .attr('stroke-width', 1);

    const node = root.append('g').selectAll('g').data(nodes).join('g').style('cursor', 'pointer');

    node
      .append('path')
      .attr('d', (d: any) =>
        d3
          .symbol()
          .type(symbolFor(d.kind))
          // size is area; match the equivalent circle radius so shapes feel even
          .size(Math.PI * Math.pow(sizeScale(d.degree), 2))(),
      )
      .attr('fill', (d: any) => color(d.category))
      .attr('stroke', (d: any) => (d.id === focus ? 'var(--ink)' : 'var(--surface)'))
      .attr('stroke-width', (d: any) => (d.id === focus ? 2.5 : 1));

    // The most-connected "hub" SOULs keep their labels in the wide view; the rest
    // reveal as you zoom in. Small/neighborhood graphs label everything.
    const degreesDesc = nodes.map((n: any) => n.degree).sort((a: number, b: number) => b - a);
    const hubMin = nodes.length > 120 ? degreesDesc[Math.min(18, degreesDesc.length - 1)] || 0 : 0;
    let activeId: string | null = focus;
    const labelVisible = (d: any) =>
      nodes.length <= 120 || !!focus ? true : zoomK >= 1.8 || d.degree >= hubMin;

    const label = node
      .append('text')
      .text((d: any) => d.title)
      .attr('x', (d: any) => sizeScale(d.degree) + 4)
      .attr('y', 4)
      .attr('font-size', 11)
      .attr('fill', 'var(--ink-soft)')
      .style('pointer-events', 'none')
      .style('opacity', (d: any) => (labelVisible(d) ? 1 : 0));

    const neighbors = new Map<string, Set<string>>();
    nodes.forEach((n) => neighbors.set(n.id, new Set([n.id])));
    links.forEach((l) => {
      neighbors.get(l.source)?.add(l.target);
      neighbors.get(l.target)?.add(l.source);
    });

    function refreshLabels() {
      label.style('opacity', (d: any) =>
        activeId ? (neighbors.get(activeId)?.has(d.id) ? 1 : 0) : labelVisible(d) ? 1 : 0,
      );
    }
    // Keep labels at a constant on-screen size by dividing out the zoom factor.
    // The x/y offsets are likewise in graph units, so they get the same 1/k
    // treatment to hold a steady ~4px gap from the (zoom-scaled) node glyph.
    function scaleLabels(k: number) {
      label
        .attr('font-size', 11 / k)
        .attr('x', (d: any) => sizeScale(d.degree) + 4 / k)
        .attr('y', 4 / k);
    }
    function highlight(id: string | null) {
      activeId = id;
      node.style('opacity', (d: any) => (!id || neighbors.get(id)?.has(d.id) ? 1 : 0.12));
      // Edges are a whisper by default (nodes carry the picture); a hovered node
      // lights up only its own connections.
      link.style('opacity', (d: any) =>
        id ? (d.source.id === id || d.target.id === id ? 0.85 : 0.025) : 0.12,
      );
      refreshLabels();
    }

    node
      .on('mouseenter', (ev: any, d: any) => {
        highlight(d.id);
        tip.style.display = 'block';
        const kindBit =
          d.kind && d.kind !== 'occupation' ? `${KIND_LABELS[d.kind] ?? d.kind} · ` : '';
        tip.textContent = `${d.title} — ${kindBit}${d.category} · ${d.degree} links`;
      })
      .on('mouseleave', () => {
        highlight(focus);
        tip.style.display = 'none';
      })
      .on('click', (ev: any, d: any) => {
        window.location.href = `${base}/souls/${d.id}`;
      });

    // Clustering: pull each node toward a per-group anchor arranged on a ring, so
    // the big graph reads as a map of domains/kinds instead of one hairball. Group
    // names render faintly behind the nodes. Disabled (free force) for small graphs.
    const baseCharge = nodes.length > 200 ? -55 : -120;
    const groupKeyOf = (d: any, mode: string) =>
      mode === 'kind' ? (KIND_LABELS[d.kind || 'occupation'] ?? d.kind) : d.category;
    let groupMode = 'none';
    let anchors = new Map<string, { x: number; y: number }>();
    const anchorOf = (d: any) => anchors.get(groupKeyOf(d, groupMode)) || { x: W / 2, y: H / 2 };
    const clusterLayer = root.insert('g', ':first-child').attr('pointer-events', 'none');

    const sim = d3
      .forceSimulation(nodes as any)
      .force(
        'link',
        d3
          .forceLink(links)
          .id((d: any) => d.id)
          .distance(focus ? 60 : 40)
          .strength(focus ? 0.3 : 0.08),
      )
      .force('charge', d3.forceManyBody().strength(baseCharge).distanceMax(360))
      .force('center', d3.forceCenter(W / 2, H / 2).strength(0.04))
      .force('x', d3.forceX((d: any) => anchorOf(d).x).strength(0.02))
      .force('y', d3.forceY((d: any) => anchorOf(d).y).strength(0.02))
      .force(
        'collide',
        d3.forceCollide().radius((d: any) => sizeScale(d.degree) + 3),
      )
      .on('tick', () => {
        link
          .attr('x1', (d: any) => d.source.x)
          .attr('y1', (d: any) => d.source.y)
          .attr('x2', (d: any) => d.target.x)
          .attr('y2', (d: any) => d.target.y);
        node.attr('transform', (d: any) => `translate(${d.x},${d.y})`);
      });

    function applyGrouping(mode: string) {
      groupMode = mode;
      anchors = new Map();
      if (mode !== 'none') {
        const groups = [...new Set(nodes.map((d: any) => groupKeyOf(d, mode)))];
        const R = Math.min(W, H) * 0.5;
        groups.forEach((g, i) => {
          const a = (i / groups.length) * 2 * Math.PI - Math.PI / 2;
          anchors.set(g, { x: W / 2 + R * Math.cos(a), y: H / 2 + R * Math.sin(a) });
        });
      }
      // Re-add the forces (not just .strength) so their per-node targets recompute
      // from the new anchors — d3 caches those at initialize time.
      const s = mode === 'none' ? 0.02 : 0.35;
      sim.force('x', d3.forceX((d: any) => anchorOf(d).x).strength(s));
      sim.force('y', d3.forceY((d: any) => anchorOf(d).y).strength(s));
      sim.force(
        'charge',
        d3
          .forceManyBody()
          .strength(mode === 'none' ? baseCharge : -22)
          .distanceMax(300),
      );
      const gl = clusterLayer.selectAll('text').data(mode === 'none' ? [] : [...anchors.entries()]);
      gl.exit().remove();
      gl.enter()
        .append('text')
        .attr('text-anchor', 'middle')
        .attr('font-size', 13)
        .attr('font-weight', 600)
        .attr('fill', 'var(--ink-faint)')
        .attr('opacity', 0.5)
        .merge(gl as any)
        .attr('x', (d: any) => d[1].x)
        .attr('y', (d: any) => d[1].y)
        .text((d: any) => d[0]);
      sim.alpha(0.7).restart();
    }

    node.call(
      d3
        .drag<any, any>()
        .on('start', (ev, d) => {
          if (!ev.active) sim.alphaTarget(0.3).restart();
          d.fx = d.x;
          d.fy = d.y;
        })
        .on('drag', (ev, d) => {
          d.fx = ev.x;
          d.fy = ev.y;
        })
        .on('end', (ev, d) => {
          if (!ev.active) sim.alphaTarget(0);
          d.fx = null;
          d.fy = null;
        }) as any,
    );

    highlight(focus); // sets the faint default edge state (focus may be null)

    // Controls
    const search = wrap.querySelector('[data-graph-search]') as HTMLInputElement | null;
    const filter = wrap.querySelector('[data-graph-filter]') as HTMLSelectElement | null;
    const count = wrap.querySelector('[data-graph-count]') as HTMLElement | null;
    if (count) count.textContent = `${nodes.length} nodes · ${links.length} edges`;
    if (search) {
      search.addEventListener('input', () => {
        const q = search.value.trim().toLowerCase();
        if (!q) {
          highlight(null);
          return;
        }
        const match = nodes.find((n: any) => n.title.toLowerCase().includes(q));
        node.style('opacity', (d: any) => (d.title.toLowerCase().includes(q) ? 1 : 0.1));
        label.style('opacity', (d: any) => (d.title.toLowerCase().includes(q) ? 1 : 0));
        if (match) {
          svg
            .transition()
            .duration(500)
            .call(
              zoom.transform as any,
              d3.zoomIdentity
                .translate(W / 2, H / 2)
                .scale(1.4)
                .translate(-(match as any).x, -(match as any).y),
            );
        }
      });
    }
    // Category (single) + kind (multi) filters HIDE non-matching nodes and any
    // edge touching a hidden node, rather than dimming. Empty kind set = all kinds.
    const selectedKinds = new Set<string>();
    const nodeShown = (d: any) => {
      const c = filter ? filter.value : '';
      return (
        (!c || d.category === c) &&
        (selectedKinds.size === 0 || selectedKinds.has(d.kind || 'occupation'))
      );
    };
    // Zoom/pan to frame a set of nodes (defaults to the currently-visible ones),
    // so filtering down to a subset fills the view instead of leaving a far clump.
    function fitTo() {
      const pts = nodes.filter((d: any) => nodeShown(d) && d.x != null);
      if (!pts.length) return;
      let minX = Infinity,
        minY = Infinity,
        maxX = -Infinity,
        maxY = -Infinity;
      for (const d of pts) {
        minX = Math.min(minX, d.x);
        maxX = Math.max(maxX, d.x);
        minY = Math.min(minY, d.y);
        maxY = Math.max(maxY, d.y);
      }
      const pad = 70;
      const w = Math.max(maxX - minX, 1);
      const h = Math.max(maxY - minY, 1);
      const k = Math.max(0.2, Math.min(2.4, 0.9 * Math.min((W - 2 * pad) / w, (H - 2 * pad) / h)));
      const cx = (minX + maxX) / 2;
      const cy = (minY + maxY) / 2;
      svg
        .transition()
        .duration(650)
        .call(
          zoom.transform as any,
          d3.zoomIdentity
            .translate(W / 2, H / 2)
            .scale(k)
            .translate(-cx, -cy),
        );
    }
    function applyFilters(fit = true) {
      node.style('display', (d: any) => (nodeShown(d) ? null : 'none'));
      link.style('display', (d: any) =>
        nodeShown(d.source) && nodeShown(d.target) ? null : 'none',
      );
      if (count) {
        const active = (filter && filter.value) || selectedKinds.size > 0;
        const vis = nodes.filter(nodeShown).length;
        count.textContent = active
          ? `${vis} of ${nodes.length} nodes`
          : `${nodes.length} nodes · ${links.length} edges`;
      }
      if (fit) fitTo();
    }
    if (filter) filter.addEventListener('change', applyFilters);

    // Kind chips: one toggle per kind present in this graph (so they only appear
    // once the Atlas covers more than occupations). Toggle any number on/off.
    const kindChips = wrap.querySelector('[data-graph-kind-chips]') as HTMLElement | null;
    if (kindChips) {
      const present = [...new Set(nodes.map((n: any) => n.kind || 'occupation'))].sort();
      if (present.length > 1) {
        const paint = (b: HTMLButtonElement, on: boolean) => {
          b.style.background = on ? 'var(--accent-soft)' : 'transparent';
          b.style.color = on ? 'var(--accent)' : 'var(--ink-soft)';
          b.style.borderColor = on ? 'var(--accent)' : 'var(--border)';
        };
        for (const k of present) {
          const b = document.createElement('button');
          b.type = 'button';
          b.className = 'rounded-md border px-2 py-1 text-xs';
          b.dataset.kind = k;
          b.setAttribute('aria-pressed', 'false');
          b.textContent = KIND_LABELS[k] ?? k;
          paint(b, false);
          b.addEventListener('click', () => {
            const on = b.getAttribute('aria-pressed') !== 'true';
            b.setAttribute('aria-pressed', String(on));
            if (on) selectedKinds.add(k);
            else selectedKinds.delete(k);
            paint(b, on);
            applyFilters();
          });
          kindChips.appendChild(b);
        }
        kindChips.classList.remove('hidden');
        kindChips.classList.add('flex');
      }
    }

    // Cluster control: defaults to "by category" on the full graph; neighborhood
    // graphs have no control and stay free-force.
    const groupSel = wrap.querySelector('[data-graph-group]') as HTMLSelectElement | null;
    if (groupSel) {
      applyGrouping(groupSel.value);
      groupSel.addEventListener('change', () => applyGrouping(groupSel.value));
    }

    const zoomTo = (d: any, k = 1.7) =>
      svg
        .transition()
        .duration(600)
        .call(
          zoom.transform as any,
          d3.zoomIdentity
            .translate(W / 2, H / 2)
            .scale(k)
            .translate(-d.x, -d.y),
        );

    // Surprise me — jump to a random visible SOUL and isolate its neighborhood.
    const randomBtn = wrap.querySelector('[data-graph-random]') as HTMLButtonElement | null;
    randomBtn?.addEventListener('click', () => {
      const pool = nodes.filter(nodeShown);
      if (!pool.length) return;
      const d = pool[Math.floor(Math.random() * pool.length)];
      highlight(d.id);
      tip.style.display = 'block';
      const kindBit =
        d.kind && d.kind !== 'occupation' ? `${KIND_LABELS[d.kind] ?? d.kind} · ` : '';
      tip.textContent = `${d.title} — ${kindBit}${d.category} · ${d.degree} links`;
      zoomTo(d);
    });

    // Reset — clear filters + selection + zoom.
    const resetBtn = wrap.querySelector('[data-graph-reset]') as HTMLButtonElement | null;
    resetBtn?.addEventListener('click', () => {
      if (search) search.value = '';
      if (filter) filter.value = '';
      selectedKinds.clear();
      wrap.querySelectorAll('[data-graph-kind-chips] button').forEach((b) => {
        b.setAttribute('aria-pressed', 'false');
        (b as HTMLElement).style.background = 'transparent';
        (b as HTMLElement).style.color = 'var(--ink-soft)';
        (b as HTMLElement).style.borderColor = 'var(--border)';
      });
      applyFilters(false);
      highlight(focus);
      tip.style.display = 'none';
      svg
        .transition()
        .duration(500)
        .call(zoom.transform as any, d3.zoomIdentity);
    });

    // Fullscreen toggle (full graph only). The SVG (100% w/h, fixed viewBox)
    // scales to fill the maximized canvas.
    const fsBtn = wrap.querySelector('[data-graph-fullscreen]') as HTMLButtonElement | null;
    if (fsBtn) {
      fsBtn.addEventListener('click', () => {
        if (document.fullscreenElement) document.exitFullscreen();
        else (wrap as HTMLElement).requestFullscreen?.();
      });
      document.addEventListener('fullscreenchange', () => {
        fsBtn.textContent = document.fullscreenElement === wrap ? '⤡ Exit' : '⤢ Fullscreen';
      });
    }

    // The clustered map is laid out larger than the canvas; once it settles,
    // frame the whole thing so nothing is cut off on load.
    if (groupSel) setTimeout(() => !activeId && fitTo(), 1500);
  }

  document.querySelectorAll('.graph-wrap').forEach((w) => initGraph(w));
</script>
