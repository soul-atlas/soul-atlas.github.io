---
import Layout from '../layouts/Layout.astro';
import { stats, activity, categories, kinds, kindLabel, categoryColor } from '../lib/data';
import { url, soulUrl } from '../lib/site';

const t = stats.totals;
const maxCat = Math.max(1, ...categories.map((c: any) => c.count));
const maxKind = Math.max(1, ...kinds.map((k: any) => k.count));

// Build a GitHub-style activity heatmap (last ~26 weeks) from commit counts.
const byDate = new Map(activity.map((a: any) => [a.date, a.count]));
const weeks: { date: string; count: number }[][] = [];
const today = new Date('2026-06-26');
const start = new Date(today);
start.setDate(start.getDate() - 7 * 26);
// align to Sunday
start.setDate(start.getDate() - start.getDay());
let cursor = new Date(start);
let maxCount = 1;
while (cursor <= today) {
  const week: { date: string; count: number }[] = [];
  for (let d = 0; d < 7; d++) {
    const iso = cursor.toISOString().slice(0, 10);
    const count = (byDate.get(iso) as number) || 0;
    maxCount = Math.max(maxCount, count);
    week.push({ date: iso, count });
    cursor.setDate(cursor.getDate() + 1);
  }
  weeks.push(week);
}
const heatColor = (n: number) => {
  if (!n) return 'var(--bg-soft)';
  const l = Math.min(1, n / maxCount);
  return `color-mix(in srgb, var(--accent) ${20 + l * 80}%, var(--bg-soft))`;
};

const statCards = [
  { label: 'SOULs', value: t.souls },
  { label: 'Graph edges', value: t.edges },
  { label: 'Categories', value: t.categories },
  { label: 'Total words', value: t.words.toLocaleString('en-US') },
  { label: 'Avg words / SOUL', value: t.avgWords },
  { label: 'Avg reading time', value: `${t.avgReadingTime} min` },
  { label: 'Contributors', value: t.contributors },
  { label: 'Tags', value: t.tags },
];

const tables: { title: string; rows: any[]; render: (r: any) => string }[] = [
  {
    title: 'Most connected',
    rows: stats.centrality.slice(0, 10),
    render: (r) => `${r.degree} links`,
  },
  {
    title: 'Most interdisciplinary',
    rows: stats.interdisciplinary.slice(0, 10),
    render: (r) => `${r.categories} domains`,
  },
  {
    title: 'Largest SOULs',
    rows: stats.largest.slice(0, 10),
    render: (r) => `${r.words.toLocaleString('en-US')} words`,
  },
  { title: 'Recently updated', rows: stats.recentlyUpdated.slice(0, 10), render: (r) => r.date },
  { title: 'Newest', rows: stats.newest.slice(0, 10), render: (r) => r.date },
  {
    title: 'Smallest SOULs',
    rows: stats.smallest.slice(0, 10),
    render: (r) => `${r.words.toLocaleString('en-US')} words`,
  },
];
---

<Layout
  title="Dashboard"
  description="Live statistics for the SOUL Atlas: coverage, connectivity, contributors, and quality."
>
  <div class="mx-auto max-w-6xl px-4 py-10">
    <h1 class="text-3xl font-bold tracking-tight" style="color:var(--ink)">Dashboard</h1>
    <p class="mt-2 max-w-2xl" style="color:var(--ink-soft)">
      Everything here is computed at build time from the repository itself — no analytics, no
      tracking.
    </p>

    <!-- Stat cards -->
    <div class="mt-6 grid grid-cols-2 gap-3 sm:grid-cols-4">
      {
        statCards.map((s) => (
          <div class="card p-4">
            <div class="text-xs uppercase tracking-wide" style="color:var(--ink-faint)">
              {s.label}
            </div>
            <div class="mt-1 text-2xl font-semibold" style="color:var(--ink)">
              {s.value}
            </div>
          </div>
        ))
      }
    </div>

    <!-- Category distribution -->
    <section class="mt-10">
      <h2 class="text-lg font-semibold" style="color:var(--ink)">Coverage by domain</h2>
      <div class="card mt-3 space-y-2 p-5">
        {
          categories.map((c: any) => (
            <a
              href={url(`/categories/${c.name.toLowerCase().replace(/[^a-z0-9]+/g, '-')}`)}
              class="block"
            >
              <div class="flex items-center justify-between text-sm">
                <span style="color:var(--ink-soft)">{c.name}</span>
                <span style="color:var(--ink-faint)">{c.count}</span>
              </div>
              <div class="mt-1 h-2 overflow-hidden rounded-full" style="background:var(--bg-soft)">
                <div
                  class="h-full rounded-full"
                  style={`width:${(c.count / maxCat) * 100}%; background:${categoryColor(c.name)}`}
                />
              </div>
            </a>
          ))
        }
      </div>
    </section>

    <!-- Kind distribution (only meaningful once we cover more than occupations) -->
    {
      kinds.length > 1 && (
        <section class="mt-10">
          <h2 class="text-lg font-semibold" style="color:var(--ink)">
            Coverage by kind
          </h2>
          <p class="mt-1 text-sm" style="color:var(--ink-faint)">
            How the Atlas is broadening past occupations toward every way humans think.
          </p>
          <div class="card mt-3 space-y-2 p-5">
            {kinds.map((k: any) => (
              <a href={url(`/souls?kind=${k.kind}`)} class="block">
                <div class="flex items-center justify-between text-sm">
                  <span style="color:var(--ink-soft)">{kindLabel(k.kind)}</span>
                  <span style="color:var(--ink-faint)">{k.count}</span>
                </div>
                <div
                  class="mt-1 h-2 overflow-hidden rounded-full"
                  style="background:var(--bg-soft)"
                >
                  <div
                    class="h-full rounded-full"
                    style={`width:${(k.count / maxKind) * 100}%; background:var(--accent)`}
                  />
                </div>
              </a>
            ))}
          </div>
        </section>
      )
    }

    <!-- Activity heatmap -->
    <section class="mt-10">
      <h2 class="text-lg font-semibold" style="color:var(--ink)">Repository activity</h2>
      <div class="card mt-3 overflow-x-auto p-5">
        <div class="flex gap-1" style="min-width:max-content">
          {
            weeks.map((week) => (
              <div class="flex flex-col gap-1">
                {week.map((d) => (
                  <span
                    class="h-2.5 w-2.5 rounded-[2px]"
                    style={`background:${heatColor(d.count)}`}
                    title={`${d.date}: ${d.count} commit(s)`}
                  />
                ))}
              </div>
            ))
          }
        </div>
        <div class="mt-3 text-xs" style="color:var(--ink-faint)">
          Commits to souls/ over the last 26 weeks.
        </div>
      </div>
    </section>

    <!-- Leaderboards -->
    <section class="mt-10 grid gap-4 md:grid-cols-2 lg:grid-cols-3">
      {
        tables.map((tb) => (
          <div class="card p-5">
            <h3
              class="mb-3 text-sm font-semibold uppercase tracking-wide"
              style="color:var(--ink-faint)"
            >
              {tb.title}
            </h3>
            <ol class="space-y-1.5 text-sm">
              {tb.rows.map((r: any, i: number) => (
                <li class="flex items-center justify-between gap-2">
                  <a
                    href={soulUrl(r.slug)}
                    class="truncate hover:underline"
                    style="color:var(--ink)"
                  >
                    <span style="color:var(--ink-faint)">{i + 1}.</span> {r.title}
                  </a>
                  <span class="shrink-0 text-xs" style="color:var(--ink-faint)">
                    {tb.render(r)}
                  </span>
                </li>
              ))}
            </ol>
          </div>
        ))
      }
    </section>

    <!-- Contributor leaderboard -->
    <section class="mt-4 grid gap-4 md:grid-cols-2">
      <div class="card p-5">
        <h3
          class="mb-3 text-sm font-semibold uppercase tracking-wide"
          style="color:var(--ink-faint)"
        >
          Top contributors
        </h3>
        <ol class="space-y-1.5 text-sm">
          {
            stats.contributors.slice(0, 12).map((cn: any, i: number) => (
              <li class="flex items-center justify-between">
                <span style="color:var(--ink)">
                  <span style="color:var(--ink-faint)">{i + 1}.</span> {cn.name}
                </span>
                <span class="text-xs" style="color:var(--ink-faint)">
                  {cn.count} SOULs
                </span>
              </li>
            ))
          }
        </ol>
      </div>

      <!-- Quality / health -->
      <div class="card p-5">
        <h3
          class="mb-3 text-sm font-semibold uppercase tracking-wide"
          style="color:var(--ink-faint)"
        >
          Health
        </h3>
        <ul class="space-y-2 text-sm" style="color:var(--ink-soft)">
          <li class="flex justify-between">
            <span>Incomplete SOULs</span><span style="color:var(--ink)"
              >{stats.quality.incomplete.length}</span
            >
          </li>
          <li class="flex justify-between">
            <span>Orphan pages (no links)</span><span style="color:var(--ink)"
              >{stats.quality.orphanPages.length}</span
            >
          </li>
          <li class="flex justify-between">
            <span>Missing metadata</span><span style="color:var(--ink)"
              >{stats.quality.missingMetadata.length}</span
            >
          </li>
          <li class="flex justify-between">
            <span>Stale (&gt;1yr unreviewed)</span><span style="color:var(--ink)"
              >{stats.quality.stalePages.length}</span
            >
          </li>
          <li class="flex justify-between">
            <span>Dangling references</span><span style="color:var(--ink)"
              >{stats.quality.danglingReferences.length}</span
            >
          </li>
          <li class="flex justify-between">
            <span>Practitioner-verified</span><span style="color:var(--ink)"
              >{t.verified} ({Math.round((t.verifiedShare || 0) * 100)}%)</span
            >
          </li>
          {
            (t.federated || 0) > 0 && (
              <li class="flex justify-between">
                <span>Federated (external, excluded from shares)</span>
                <span style="color:var(--ink)">{t.federated}</span>
              </li>
            )
          }
        </ul>
        <p class="mt-3 text-xs" style="color:var(--ink-faint)">
          Most SOULs are AI-drafted first passes awaiting review by people who do the work.{' '}
          <a href={url('/suggest')} class="underline">Help verify one →</a>
        </p>
      </div>
    </section>
  </div>
</Layout>
