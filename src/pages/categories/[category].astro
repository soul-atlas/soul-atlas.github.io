---
import Layout from '../../layouts/Layout.astro';
import SoulCard from '../../components/SoulCard.astro';
import { souls, categories } from '../../lib/data';
import { slugifyCat } from '../../lib/site';

export function getStaticPaths() {
  return categories.map((c: any) => ({
    params: { category: slugifyCat(c.name) },
    props: { name: c.name },
  }));
}

const { name } = Astro.props;
const list = souls
  .filter((s) => s.category === name)
  .sort((a, b) => a.title.localeCompare(b.title));
---

<Layout title={name} description={`Every SOUL in the ${name} domain.`}>
  <div class="mx-auto max-w-6xl px-4 py-10">
    <div class="text-sm" style="color:var(--ink-faint)">Domain</div>
    <h1 class="text-3xl font-bold tracking-tight" style="color:var(--ink)">{name}</h1>
    <p class="mt-2" style="color:var(--ink-soft)">{list.length} ways of thinking in this domain.</p>
    <div class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {list.map((s) => <SoulCard soul={s} />)}
    </div>
  </div>
</Layout>
