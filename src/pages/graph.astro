---
import Layout from '../layouts/Layout.astro';
import GraphView from '../components/GraphView.astro';
import { graph, stats, CATEGORY_COLORS } from '../lib/data';
import { url } from '../lib/site';

const legend = Object.entries(CATEGORY_COLORS).filter(([name]) =>
  graph.nodes.some((n) => n.category === name),
);
---

<Layout
  title="Knowledge Graph"
  description="The interactive map of how ways of thinking relate — specialization, adjacency, collaboration, and progression."
>
  <div class="mx-auto max-w-6xl px-4 py-8">
    <div class="flex flex-wrap items-end justify-between gap-3">
      <div>
        <h1 class="text-3xl font-bold tracking-tight" style="color:var(--ink)">Knowledge Graph</h1>
        <p class="mt-2 max-w-2xl" style="color:var(--ink-soft)">
          Every occupation is a node; every typed relationship an edge. Drag to rearrange, scroll to zoom, hover to
          isolate a neighborhood, click to open. {graph.nodes.length} nodes · {graph.edges.length} edges.
        </p>
      </div>
      <a href={url('/dashboard')} class="btn text-sm">Graph statistics →</a>
    </div>

    <div class="mt-6">
      <GraphView height={640} controls={true} id="full" />
    </div>

    <div class="mt-4 flex flex-wrap gap-x-4 gap-y-2">
      {
        legend.map(([name, c]) => (
          <span class="inline-flex items-center gap-1.5 text-xs" style="color:var(--ink-soft)">
            <span class="inline-block h-2.5 w-2.5 rounded-full" style={`background:${c}`} />
            {name}
          </span>
        ))
      }
    </div>

    <div class="mt-8 grid gap-4 sm:grid-cols-3">
      <div class="card p-4">
        <div class="text-xs uppercase tracking-wide" style="color:var(--ink-faint)">Graph density</div>
        <div class="mt-1 text-2xl font-semibold" style="color:var(--ink)">{stats.totals.graphDensity}</div>
      </div>
      <div class="card p-4">
        <div class="text-xs uppercase tracking-wide" style="color:var(--ink-faint)">Orphan nodes</div>
        <div class="mt-1 text-2xl font-semibold" style="color:var(--ink)">{stats.quality.orphanPages.length}</div>
      </div>
      <div class="card p-4">
        <div class="text-xs uppercase tracking-wide" style="color:var(--ink-faint)">Most connected</div>
        <div class="mt-1 text-lg font-semibold" style="color:var(--ink)">
          {stats.centrality[0]?.title ?? '—'}
        </div>
      </div>
    </div>
  </div>
</Layout>
