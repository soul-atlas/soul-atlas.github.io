{
  "printWidth": 100,
  "singleQuote": true,
  "trailingComma": "all",
  "semi": true,
  "plugins": ["prettier-plugin-astro"],
  "overrides": [
    {
      "files": "*.astro",
      "options": { "parser": "astro" }
    },
    {
      "files": ["*.md", "occupations/**/*.md"],
      "options": { "proseWrap": "preserve", "printWidth": 80 }
    }
  ]
}
