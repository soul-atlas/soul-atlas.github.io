# Canonical site origin (no trailing slash). Used for sitemaps, canonical URLs, RSS.
SITE_URL=https://soul-atlas.github.io

# Base path the site is served from. "/" for a user/org page (soul-atlas.github.io),
# or "/<repo>" for a GitHub Pages project site.
BASE_PATH=/

# GitHub repo slug used for "edit", "history", and "blame" deep links.
GITHUB_REPO=soul-atlas/soul-atlas.github.io
