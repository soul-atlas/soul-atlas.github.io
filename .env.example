# Canonical site origin (no trailing slash). Used for sitemaps, canonical URLs, RSS.
SITE_URL=https://soul-atlas.github.io

# Base path the site is served from. "/" for a user/org page (soul-atlas.github.io),
# or "/<repo>" for a GitHub Pages project site.
BASE_PATH=/

# GitHub repo slug used for "edit", "history", and "blame" deep links.
GITHUB_REPO=soul-atlas/soul-atlas.github.io

# Endpoint for the no-account "Suggest a change" flow (the Cloudflare Worker in
# workers/suggest). Leave unset to fall back to opening a prefilled GitHub issue —
# the site is fully functional either way. Must start with PUBLIC_ to reach the client.
PUBLIC_SUGGEST_ENDPOINT=

# Optional Cloudflare Turnstile site key for bot protection on the suggestion form.
# Pair it with the worker's TURNSTILE_SECRET. Leave unset to disable.
PUBLIC_TURNSTILE_SITE_KEY=
