# Canonical site origin (no trailing slash). Used for sitemaps, canonical URLs, RSS.
SITE_URL=https://open-soul.github.io

# Base path the site is served from. Use "/soul-atlas" for GitHub Pages project
# sites, or "/" for a custom domain / user site.
BASE_PATH=/soul-atlas

# GitHub repo slug used for "edit", "history", and "blame" deep links.
GITHUB_REPO=open-soul/soul-atlas
